const axios = require("axios");

function normalizePlate(s) {
  return (s || "").toString().toUpperCase().replace(/[^A-Z0-9]/g, "");
}

function maskText(v) {
  const s = (v ?? "").toString();
  if (s.length <= 1) return s;
  return s[0] + "*".repeat(s.length - 1);
}

function parseDateLoose(v) {
  if (!v) return null;

  if (v instanceof Date && !isNaN(v.getTime())) return v;

  if (typeof v === "number") {
    const excelEpoch = new Date(Date.UTC(1899, 11, 30));
    const d = new Date(excelEpoch.getTime() + v * 86400000);
    return isNaN(d.getTime()) ? null : d;
  }

  if (typeof v === "string") {
    const t = v.trim();

    let m = t.match(/^(\d{2})-(\d{2})-(\d{4})$/); // DD-MM-YYYY
    if (m) return new Date(Number(m[3]), Number(m[2]) - 1, Number(m[1]));

    m = t.match(/^(\d{4})-(\d{2})-(\d{2})$/); // YYYY-MM-DD
    if (m) return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));

    const d = new Date(t);
    if (!isNaN(d.getTime())) return d;
  }

  return null;
}

function fmtDDMMMaskYear(d) {
  const dd = String(d.getDate()).padStart(2, "0");
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  return `${dd}-${mm}-****`;
}

async function getAccessToken() {
  const { TENANT_ID, CLIENT_ID, CLIENT_SECRET } = process.env;

  const url = `https://login.microsoftonline.com/${TENANT_ID}/oauth2/v2.0/token`;
  const params = new URLSearchParams();
  params.append("client_id", CLIENT_ID);
  params.append("client_secret", CLIENT_SECRET);
  params.append("scope", "https://graph.microsoft.com/.default");
  params.append("grant_type", "client_credentials");

  const resp = await axios.post(url, params.toString(), {
    headers: { "Content-Type": "application/x-www-form-urlencoded" },
  });

  return resp.data.access_token;
}

async function readTableRange(token) {
  const { DRIVE_ID, ITEM_ID, TABLE_NAME } = process.env;

  const url =
    `https://graph.microsoft.com/v1.0/drives/${DRIVE_ID}` +
    `/items/${ITEM_ID}/workbook/tables('${encodeURIComponent(TABLE_NAME)}')/range`;

  const resp = await axios.get(url, {
    headers: { Authorization: `Bearer ${token}` },
  });

  const values = resp.data.values;
  if (!Array.isArray(values) || values.length < 2) {
    throw new Error("La tabla no tiene encabezados/datos suficientes.");
  }

  const headers = values[0].map((h) => (h ?? "").toString().trim());
  const rows = values.slice(1);
  return { headers, rows };
}

module.exports = async function (context, req) {
  try {
    const plate = normalizePlate(req.body?.plate);
    if (!plate) {
      context.res = { status: 400, body: "⚠️ No se proporcionó una placa válida." };
      return;
    }

    let sDate = req.body?.startDate ? parseDateLoose(req.body.startDate) : null;
    let eDate = req.body?.endDate ? parseDateLoose(req.body.endDate) : null;
    if (sDate) sDate.setHours(0, 0, 0, 0);
    if (eDate) eDate.setHours(23, 59, 59, 999);

    const requiredEnv = ["TENANT_ID", "CLIENT_ID", "CLIENT_SECRET", "DRIVE_ID", "ITEM_ID", "TABLE_NAME"];
    for (const k of requiredEnv) {
      if (!process.env[k]) {
        context.res = { status: 500, body: `⚠️ Falta variable de entorno: ${k}` };
        return;
      }
    }

    const token = await getAccessToken();
    const { headers, rows } = await readTableRange(token);

    const idx = {};
    headers.forEach((h, i) => { if (h) idx[h] = i; });

    const requiredCols = ["PLACA", "FECHAS VIAJES", "CONDUCTOR", "PAGADO EL", "CUMPLIDO EL", "ESTADO DE CUMPLIDO"];
    for (const c of requiredCols) {
      if (idx[c] === undefined) {
        context.res = { status: 500, body: `⚠️ Falta la columna requerida: ${c}` };
        return;
      }
    }

    const omit = new Set([
      "ESTADO SALDO",
      "DESTINO",
      "PESO",
      "VALOR TONELADA",
      "TRINCADO",
      "SALDO A PAGAR",
      "AUMENTO DE FLETE",
      "OBSERVACIONES",
      "ANTICIPO APRUEBA MCLAUDIA",
      "SALDO APRUEBA KELLY",
    ]);

    const matches = [];
    for (const row of rows) {
      const p = normalizePlate(row[idx["PLACA"]]);
      if (p !== plate) continue;

      const viaje = parseDateLoose(row[idx["FECHAS VIAJES"]]);
      const inRange =
        (!sDate && !eDate) ||
        (viaje && (!sDate || viaje >= sDate) && (!eDate || viaje <= eDate));

      if (inRange) matches.push({ row, viaje });
    }

    if (!matches.length) {
      context.res = { status: 200, body: "⚠️ No se encontraron operaciones para la placa indicada." };
      return;
    }

    matches.sort((a, b) => {
      const ta = a.viaje ? a.viaje.getTime() : -Infinity;
      const tb = b.viaje ? b.viaje.getTime() : -Infinity;
      return tb - ta;
    });

    let output = "Resultados encontrados:\n\n";

    for (const { row } of matches) {
      output += "----------------------\n";

      for (let i = 0; i < headers.length; i++) {
        const h = headers[i];
        if (!h || omit.has(h)) continue;

        let val = row[i];

        if (h === "FECHAS VIAJES" || h === "PAGADO EL" || h === "CUMPLIDO EL") {
          const d = parseDateLoose(val);
          val = d ? fmtDDMMMaskYear(d) : (val ?? "");
        }

        if (h === "PLACA" || h === "CONDUCTOR") {
          val = maskText(val);
        }

        output += `${h}: ${val ?? ""}\n`;
      }
    }

    context.res = { status: 200, body: output };
  } catch (err) {
    context.log(err?.response?.data || err);
    context.res = { status: 500, body: "⚠️ Error interno." };
  }
};
